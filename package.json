{
  "name": "is-app-template",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "dev": "concurrently -n \"web,api\" -c \"cyan.bold,green.bold\" \"pnpm dev:frontend\" \"pnpm dev:backend\"",
    "dev:frontend": "pnpm --filter @client/web dev",
    "dev:backend": "mvn -f apps/api/pom.xml spring-boot:run",
    "build": "turbo run build",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "turbo": "^2.0.14",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.4"
  }
}
